# Gemini API Key (used for OCR & Chat PDF)
GEMINI_API_KEY="your-gemini-api-key-here"

# Hugging Face Inference API Key (used for AI Summarizer - facebook/bart-large-cnn)
# Free tier: https://huggingface.co/settings/tokens
HF_API_KEY="hf_your_token_here"

# Google Cloud Vision API Key (used for OCR)
GOOGLE_VISION_API_KEY="your-vision-api-key-here"

# Adobe PDF Services (used for PDF to Word conversion)
ADOBE_CLIENT_ID="your-adobe-client-id"
ADOBE_CLIENT_SECRET="your-adobe-client-secret"

# Google Analytics
VITE_GA_ID=G-XXXXXXXXXX

# Backend API URL (production)
VITE_API_URL="https://your-backend-url.onrender.com"

# Email configuration for error reporting
SMTP_HOST="smtp.example.com"
SMTP_PORT="587"
SMTP_USER="your-email@example.com"
SMTP_PASS="your-email-password"
ADMIN_EMAIL="admin@example.com"

# Razorpay keys
RAZORPAY_KEY_ID="your-razorpay-key-id"
RAZORPAY_KEY_SECRET="your-razorpay-key-secret"
